{
  "annotations": { "list": [] },
  "description": "G-ARVIS LLM Observability Dashboard for argus-ai",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "G-ARVIS Composite Score",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "argus_garvis_composite",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 0.6 },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.8 }
            ]
          },
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        }
      }
    },
    {
      "title": "G-ARVIS Dimensions",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [
        { "expr": "argus_garvis_groundedness", "legendFormat": "Groundedness" },
        { "expr": "argus_garvis_accuracy", "legendFormat": "Accuracy" },
        { "expr": "argus_garvis_reliability", "legendFormat": "Reliability" },
        { "expr": "argus_garvis_variance", "legendFormat": "Variance" },
        { "expr": "argus_garvis_inference_cost", "legendFormat": "Inference Cost" },
        { "expr": "argus_garvis_safety", "legendFormat": "Safety" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Safety Score",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "argus_garvis_safety", "legendFormat": "{{model}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 0.7 },
              { "color": "green", "value": 0.85 }
            ]
          },
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        }
      }
    },
    {
      "title": "Composite Score Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "argus_garvis_composite", "legendFormat": "{{model}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "red", "value": 0.7 }
            ]
          }
        }
      }
    },
    {
      "title": "Evaluation Latency (ms)",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(argus_evaluation_duration_ms_bucket[5m])",
          "legendFormat": "{{le}}ms"
        }
      ]
    },
    {
      "title": "Total Evaluations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sum(argus_evaluations_total)", "legendFormat": "Total" }
      ]
    },
    {
      "title": "Pass Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "sum(argus_evaluations_total{passing='true'}) / sum(argus_evaluations_total) * 100",
          "legendFormat": "Pass %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "title": "Total Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        { "expr": "sum(argus_alerts_total)", "legendFormat": "Alerts" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "Alerts by Dimension",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "sum by (dimension) (argus_alerts_total)",
          "legendFormat": "{{dimension}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["argus", "garvis", "llm", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "ARGUS - G-ARVIS LLM Observability",
  "uid": "argus-garvis-dashboard",
  "version": 1
}
